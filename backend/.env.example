ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_JWT_SECRET=change_this_to_a_strong_secret
PORT=5000

# SMTP configuration for enquiry email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
# Optional. If empty, SMTP_USER will be used as sender.
MAIL_FROM=

# MongoDB Atlas / MongoDB connection
# Example (Atlas): mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=
MONGODB_DB_NAME=standard-engineering
MONGODB_PRODUCTS_COLLECTION=products
MONGODB_ENQUIRIES_COLLECTION=enquiries
MONGODB_ADMINS_COLLECTION=admins
